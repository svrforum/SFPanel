{
  "identifier": "default",
  "description": "Default capabilities for SFPanel desktop",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "updater:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://*" },
        { "url": "https://*" },
        { "url": "ws://*" },
        { "url": "wss://*" }
      ]
    }
  ]
}
